<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">
    
    <display-name>ProcureGov Tender Management System</display-name>
    
    <!-- Welcome files -->
    <welcome-file-list>
        <welcome-file>jsp/login.jsp</welcome-file>
    </welcome-file-list>
    
    <!-- Context parameters -->
    <context-param>
        <param-name>upload.directory</param-name>
        <param-value>${catalina.base}/procuregov-uploads</param-value>
    </context-param>
    
    <!-- Session config -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
    
    <!-- JNDI DataSource -->
    <resource-ref>
        <res-ref-name>jdbc/ProcureGovDB</res-ref-name>
        <res-type>javax.sql.DataSource</res-type>
        <res-auth>Container</res-auth>
    </resource-ref>
    
    <!-- ========== JNDI MAIL SESSION (Module 6 - Bonus) ========== -->
    <resource-ref>
        <description>Mail Session for Email Notifications</description>
        <res-ref-name>mail/ProcureGovMail</res-ref-name>
        <res-type>javax.mail.Session</res-type>
        <res-auth>Container</res-auth>
    </resource-ref>
    
    <!-- ========== FILTERS ========== -->
    <filter>
        <filter-name>AuthenticationFilter</filter-name>
        <filter-class>filter.AuthenticationFilter</filter-class>
    </filter>
    
    <filter>
        <filter-name>RoleFilter</filter-name>
        <filter-class>filter.RoleFilter</filter-class>
    </filter>
    
    <!-- Officer Role Filter -->
    <filter>
        <filter-name>OfficerRoleFilter</filter-name>
        <filter-class>filter.RoleFilter</filter-class>
        <init-param>
            <param-name>roles</param-name>
            <param-value>PROCUREMENT_OFFICER</param-value>
        </init-param>
    </filter>
    
    <!-- Supplier Role Filter -->
    <filter>
        <filter-name>SupplierRoleFilter</filter-name>
        <filter-class>filter.RoleFilter</filter-class>
        <init-param>
            <param-name>roles</param-name>
            <param-value>SUPPLIER</param-value>
        </init-param>
    </filter>
    
    <!-- Evaluation Role Filter (Officer + Committee) -->
    <filter>
        <filter-name>EvaluationRoleFilter</filter-name>
        <filter-class>filter.RoleFilter</filter-class>
        <init-param>
            <param-name>roles</param-name>
            <param-value>PROCUREMENT_OFFICER,EVALUATION_COMMITTEE</param-value>
        </init-param>
    </filter>
    
    <!-- Filter Mappings -->
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/officer/*</url-pattern>
        <url-pattern>/supplier/*</url-pattern>
        <url-pattern>/evaluation/*</url-pattern>
    </filter-mapping>
    
    <filter-mapping>
        <filter-name>OfficerRoleFilter</filter-name>
        <url-pattern>/officer/*</url-pattern>
    </filter-mapping>
    
    <filter-mapping>
        <filter-name>SupplierRoleFilter</filter-name>
        <url-pattern>/supplier/*</url-pattern>
    </filter-mapping>
    
    <filter-mapping>
        <filter-name>EvaluationRoleFilter</filter-name>
        <url-pattern>/evaluation/*</url-pattern>
    </filter-mapping>
    
    <!-- ========== AUTH SERVLETS (Module 1) ========== -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>servlet.RegistrationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    
    <!-- ========== TENDER SERVLETS (Module 2) ========== -->
    <servlet>
        <servlet-name>CreateTenderServlet</servlet-name>
        <servlet-class>servlet.CreateTenderServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CreateTenderServlet</servlet-name>
        <url-pattern>/officer/createTender</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>EditTenderServlet</servlet-name>
        <servlet-class>servlet.EditTenderServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EditTenderServlet</servlet-name>
        <url-pattern>/officer/editTender</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>TenderListServlet</servlet-name>
        <servlet-class>servlet.TenderListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TenderListServlet</servlet-name>
        <url-pattern>/officer/tenderList</url-pattern>
        <url-pattern>/supplier/tenders</url-pattern>
        <url-pattern>/evaluation/tenders</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>UpdateTenderStatusServlet</servlet-name>
        <servlet-class>servlet.UpdateTenderStatusServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpdateTenderStatusServlet</servlet-name>
        <url-pattern>/officer/updateStatus</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>DownloadTenderNoticeServlet</servlet-name>
        <servlet-class>servlet.DownloadTenderNoticeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DownloadTenderNoticeServlet</servlet-name>
        <url-pattern>/download/notice</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>AwardContractServlet</servlet-name>
        <servlet-class>servlet.AwardContractServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AwardContractServlet</servlet-name>
        <url-pattern>/officer/awardContract</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>AwardNoticeServlet</servlet-name>
        <servlet-class>servlet.AwardNoticeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AwardNoticeServlet</servlet-name>
        <url-pattern>/tender/awardNotice</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>TenderResultNoticeServlet</servlet-name>
        <servlet-class>servlet.TenderResultNoticeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TenderResultNoticeServlet</servlet-name>
        <url-pattern>/officer/resultNotice</url-pattern>
    </servlet-mapping>
    
    <!-- ========== BID SERVLETS (Module 3) ========== -->
    <servlet>
        <servlet-name>SupplierDashboardServlet</servlet-name>
        <servlet-class>servlet.SupplierDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SupplierDashboardServlet</servlet-name>
        <url-pattern>/supplier/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>TenderDetailServlet</servlet-name>
        <servlet-class>servlet.TenderDetailsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TenderDetailServlet</servlet-name>
        <url-pattern>/tender/details</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SubmitBidServlet</servlet-name>
        <servlet-class>servlet.SubmitBidServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SubmitBidServlet</servlet-name>
        <url-pattern>/supplier/submitBid</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DownloadBidDocumentServlet</servlet-name>
        <servlet-class>servlet.DownloadBidDocument</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DownloadBidDocumentServlet</servlet-name>
        <url-pattern>/download/bidDocument</url-pattern>
    </servlet-mapping>
    
    <!-- ========== EVALUATION SERVLETS (Module 4) ========== -->
    <servlet>
        <servlet-name>EvaluationPanelServlet</servlet-name>
        <servlet-class>servlet.EvaluationPanelServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EvaluationPanelServlet</servlet-name>
        <url-pattern>/evaluation/panel</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ScoreEntryServlet</servlet-name>
        <servlet-class>servlet.ScoreEntryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ScoreEntryServlet</servlet-name>
        <url-pattern>/evaluation/scoreEntry</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SubmitScoresServlet</servlet-name>
        <servlet-class>servlet.SubmitScoresServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SubmitScoresServlet</servlet-name>
        <url-pattern>/evaluation/submitScores</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>EvaluationResultsServlet</servlet-name>
        <servlet-class>servlet.EvaluationResultsServlets</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EvaluationResultsServlet</servlet-name>
        <url-pattern>/evaluation/results</url-pattern>
    </servlet-mapping>
    
    <!-- ========== ERROR PAGES ========== -->
    <error-page>
        <error-code>404</error-code>
        <location>/jsp/404.jsp</location>
    </error-page>
    
    <error-page>
        <error-code>500</error-code>
        <location>/jsp/500.jsp</location>
    </error-page>
    
    <error-page>
        <error-code>403</error-code>
        <location>/jsp/accessDenied.jsp</location>
    </error-page>

    <error-page>
        <exception-type>java.lang.Exception</exception-type>
        <location>/jsp/genericError.jsp</location>
    </error-page>
    
</web-app>